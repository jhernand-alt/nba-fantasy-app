{
  "name": "nba-fantasy-app",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "build": "electron-builder --win --portable"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.nba.fantasy",
    "win": {
      "target": "portable"
    },
    "files": [
      "**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}


